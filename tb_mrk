# Q8  Cross-Tabulation: MO Risk vs Algorithmic Risk

```{r q8-clean}
df <- df |>
  mutate(
    mo_risk_clean = case_when(
      str_detect(tolower(final_risk_stratification_by_the_medical_officer),
                 "high")     ~ "High risk (MO)",
      str_detect(tolower(final_risk_stratification_by_the_medical_officer),
                 "moderate") ~ "Moderate risk (MO)",
      str_detect(tolower(final_risk_stratification_by_the_medical_officer),
                 "low")      ~ "Low risk (MO)",
      TRUE                   ~ "Unknown / Missing"
    ),
    mo_risk_clean = factor(mo_risk_clean,
                           levels = c("Low risk (MO)", "Moderate risk (MO)",
                                      "High risk (MO)", "Unknown / Missing"))
  )

undertriage_n <- df |>
  filter(mo_risk_clean == "Low risk (MO)",
         algo_risk     == "High risk (algo)") |>
  nrow()

cat(sprintf(
  "Patients classified LOW by MO but HIGH algorithmically: %d (%.1f%%)\n",
  undertriage_n, undertriage_n / nrow(df) * 100
))
```

```{r q8-crosstab}
# Wide cross-tabulation table
ct_wide <- df |>
  filter(mo_risk_clean != "Unknown / Missing", !is.na(algo_risk)) |>
  count(mo_risk_clean, algo_risk) |>
  pivot_wider(names_from = algo_risk, values_from = n, values_fill = 0) |>
  rename(`MO Risk` = mo_risk_clean)

ct_wide |>
  flextable() |>
  bg(i = ~ `MO Risk` == "Low risk (MO)",
     j = "High risk (algo)", bg = "#FCA5A5") |>
  bold(i = ~ `MO Risk` == "Low risk (MO)",
       j = "High risk (algo)") |>
  autofit() |>
  theme_vanilla()
```

```{r q8-heatmap, fig.width=9, fig.height=6}
