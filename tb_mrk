# Q6 Does Age Follow a Normal Distribution?

```{r q6-tests}
age_vals <- na.omit(df$age)

# Shapiro-Wilk test
sw <- shapiro.test(sample(age_vals, min(length(age_vals), 5000)))

# Anderson-Darling test (nortest package)
ad_res <- ad.test(age_vals)

# Manual skewness
skew_val <- round(
  (sum((age_vals - mean(age_vals))^3) / length(age_vals)) / sd(age_vals)^3,
  3
)

tibble(
  Test      = c("Shapiro-Wilk", "Anderson-Darling"),
  Statistic = c(round(sw$statistic, 4), round(ad_res$statistic, 4)),
  `p-value` = c(format.pval(sw$p.value,  digits = 4),
                format.pval(ad_res$p.value, digits = 4)),
  Decision  = c(
    ifelse(sw$p.value     < 0.05, "Reject normality", "Cannot reject normality"),
    ifelse(ad_res$p.value < 0.05, "Reject normality", "Cannot reject normality")
  )
) |>
  flextable() |>
  autofit() |>
  theme_vanilla()
```

```{r q6-plots, fig.width=11, fig.height=5}
p_hist <- ggplot(df, aes(x = age)) +
  geom_histogram(aes(y = after_stat(density)),
                 bins = 25, fill = PAL[1], colour = "white", alpha = 0.85) +
  geom_density(colour = PAL[3], linewidth = 1.1) +
  stat_function(fun  = dnorm,
                args = list(mean = mean(age_vals), sd = sd(age_vals)),
                colour = PAL[4], linewidth = 1.1, linetype = "dashed") +
  annotate("text", x = max(age_vals) * 0.97, y = Inf,
           label = paste0("SW p = ", format.pval(sw$p.value, digits = 3)),
           hjust = 1, vjust = 1.8, size = 3.5,
           colour = ifelse(sw$p.value < 0.05, PAL[3], PAL[2])) +
  labs(title    = "Age Distribution",
       subtitle = "Red = KDE  |  Orange dashed = Normal curve",
       x = "Age (years)", y = "Density") +
  theme_classic(base_size = 12)

p_qq <- ggqqplot(df, x = "age", colour = PAL[1], conf.int = TRUE) +
  labs(title = "Q-Q Plot of Age") +
  theme_classic(base_size = 12)

ggarrange(p_hist, p_qq, ncol = 2, labels = c("A", "B"))
```


