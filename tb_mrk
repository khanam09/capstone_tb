# Q3 Mean Delay and Mean Age (Replace Missing with Mean)

```{r q3}
# Delay = end - start in days
df <- df |>
  mutate(delay_days = as.numeric(difftime(end, start, units = "days")))

mean_delay <- mean(df$delay_days, na.rm = TRUE)
mean_age   <- mean(df$age,        na.rm = TRUE)

# Replace missing values with mean
df <- df |>
  mutate(
    delay_days = if_else(is.na(delay_days), round(mean_delay), delay_days),
    age        = if_else(is.na(age),        mean_age,          age)
  )

cat(sprintf("Mean delay in assessment : %.2f days\n", mean_delay))
cat(sprintf("Mean age of patients     : %.2f years\n", mean_age))
```

```{r q3-table, echo=FALSE}
tibble(
  Metric = c("Mean delay in assessment", "Mean age of patients"),
  Value  = c(paste0(round(mean_delay, 2), " days"),
             paste0(round(mean_age,   2), " years"))
) |>
  flextable() |>
  autofit() |>
  theme_vanilla()
```

