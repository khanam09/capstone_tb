# Q7 Risk Stratification by Abnormal Parameter Count

```{r q7}
df <- df |>
  mutate(
    algo_risk = case_when(
      no_of_abnormal_parameters <= 1 ~ "Low risk (algo)",
      no_of_abnormal_parameters <= 3 ~ "Moderate risk (algo)",
      no_of_abnormal_parameters >= 4 ~ "High risk (algo)",
      TRUE ~ NA_character_
    ),
    algo_risk = factor(algo_risk,
                       levels = c("Low risk (algo)",
                                  "Moderate risk (algo)",
                                  "High risk (algo)"))
  )

risk_summary <- df |>
  count(algo_risk) |>
  mutate(Percentage = paste0(round(n / nrow(df) * 100, 1), "%"))

risk_summary |>
  rename(`Risk Category` = algo_risk, Count = n) |>
  flextable() |>
  autofit() |>
  theme_vanilla()
```

```{r fig.width=7, fig.height=5}                                              
  risk_order <- c("Low risk (algo)", "Moderate risk (algo)", "High risk (algo)")
                                                                                
  risk_summary |>                                                               
    ggplot(aes(x = algo_risk, y = n, fill = algo_risk)) +                       
    geom_col(width = 0.55, colour = "white") +                                  
    geom_text(aes(label = paste0(n, "\n(", Percentage, ")")),
              vjust = -0.25, fontface = "bold", size = 4.2) +                   
    scale_fill_manual(values = setNames(c(PAL[2], PAL[4], PAL[3]),
                                        risk_order)) +                          
    scale_x_discrete(labels = c("Low\n(≤1 abnormal)",
                                 "Moderate\n(2–3 abnormal)",                    
                                 "High\n(≥4 abnormal)")) +                      
    scale_y_continuous(expand = expansion(mult = c(0, 0.18))) +
    labs(title = "Patient Count by Algorithmic Risk Stratification",            
         x = "Risk Category", y = "Number of Patients") +                       
    theme_classic(base_size = 13) +
    theme(legend.position = "none")                                             
```
  
  
  
